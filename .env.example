# Copy to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# ── PayU (Test credentials initially, swap to Prod for launch) ──
# Get from: https://merchant.payu.in/account/api-credentials
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_BASE_URL=https://test.payu.in
# Production: https://secure.payu.in

# ── Firebase Admin SDK ──
# Get service account JSON from:
# https://console.firebase.google.com/project/ask-krishna-ji/settings/serviceaccounts/adminsdk
# Paste the full JSON content as a single-line string here.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── SMTP (email + invoice) ──
# Default: Gmail SMTP with an App Password. Free, 500 emails/day limit.
#
# Setup (5 min):
#   1. Enable 2-Step Verification on the sending Gmail account.
#   2. https://myaccount.google.com/apppasswords → create "Ask Krishna Ji"
#   3. Copy the 16-char password into SMTP_PASS below.
#
# IMPORTANT — sender address rules:
#   Gmail enforces that the "From" address matches the authenticated user.
#   That means SMTP_SENDER_EMAIL must equal SMTP_USER, OR you must have
#   pre-configured "Send mail as" in Gmail settings for any other address.
#
#   For MVP just use the same Gmail address for both. Recipients see:
#     "Ask Krishna Ji" <askkrishnaji@gmail.com>
#
#   To send from noreply@askkrishnaji.com instead (fully branded):
#     - Use a custom-domain SMTP (Zoho Mail free / Google Workspace),
#     - Then both SMTP_USER and SMTP_SENDER_EMAIL = noreply@askkrishnaji.com,
#     - And SMTP_HOST changes to that provider's SMTP host.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=askkrishnaji@gmail.com   # the Gmail address that logs in
SMTP_PASS=             # 16-char Gmail App Password (NOT your regular password)
# Leave SMTP_SENDER_EMAIL = SMTP_USER unless you've set up "Send mail as".
SMTP_SENDER_EMAIL=askkrishnaji@gmail.com
SMTP_SENDER_NAME=Ask Krishna Ji

# ── Authentication (admin + pracharak portal) ──
# Long random string for JWT signing. Generate fresh, never commit.
JWT_SECRET=

# Comma-separated admin emails (lowercase). Auth gates /admin to these.
ADMIN_EMAILS=

# Temporary bootstrap password for first admin login. Clear after first use.
INITIAL_ADMIN_PASSWORD=

# ── App / deep link ──
# Used in payment-success redirect back into the app.
APP_DEEP_LINK_SCHEME=askkrishnaji
APP_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.askkrishnaji.app

# ── Public site URL (for absolute links in emails, redirects) ──
NEXT_PUBLIC_SITE_URL=https://askkrishnaji.com

# ── Premium pricing (single source of truth) ──
NEXT_PUBLIC_PREMIUM_PRICE_INR=999
NEXT_PUBLIC_PRACHARAK_BULK_PRICE_INR=500
NEXT_PUBLIC_PRACHARAK_BULK_MIN_QTY=5
